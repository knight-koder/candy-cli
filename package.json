{
  "name": "candy-cli",
  "version": "1.0.0",
  "private": true,
  "description": "Scaffolding CLI for Production-grade NestJS microservices. Interactively generates scalable services with REST, GraphQL, gRPC, Kafka, RabbitMQ, BullMQ, Redis, OpenTelemetry, Prometheus, Swagger, circuit breakers, and DLQs.",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "candy-cli": "./dist/index.js"
  },
  "files": [
    "dist",
    "templates"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/index.js",
    "prepare": "npm run build",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js"
  },
  "keywords": [
    "nestjs",
    "microservice",
    "scaffold",
    "cli",
    "kafka",
    "rabbitmq",
    "bullmq",
    "redis",
    "graphql",
    "grpc",
    "opentelemetry",
    "prometheus",
    "swagger",
    "circuit-breaker",
    "opossum",
    "typescript"
  ],
  "author": "Ashish Kushwaha",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "ejs": "^5.0.2",
    "fs-extra": "^11.3.5",
    "inquirer": "^13.4.3",
    "ora": "^9.4.0",
    "ts-morph": "^28.0.0",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/ejs": "^3.1.5",
    "@types/fs-extra": "^11.0.4",
    "@types/inquirer": "^9.0.9",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.2",
    "@types/yaml": "^1.9.6",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  }
}
