# Environment Configuration for my-microservice

# Application
NODE_ENV=development
PORT=3000
SERVICE_NAME=my-microservice


# HTTP Adapter
# Using Express



# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_SSL=false
# KAFKA_SASL_USERNAME=
# KAFKA_SASL_PASSWORD=





# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=
REDIS_TTL=60



# PostgreSQL (TypeORM)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=my-microservice











