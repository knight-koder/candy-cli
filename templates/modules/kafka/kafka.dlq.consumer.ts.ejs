import { Controller } from '@nestjs/common';
import { MessagePattern, Payload, EventPattern } from '@nestjs/microservices';

@Controller()
export class KafkaConsumerController {
  /**
   * Listens to 'my-topic'. Failed messages after maxRetries
   * will be forwarded to 'my-topic.dlq'.
   */
  @MessagePattern('my-topic')
  async handleMessage(@Payload() message: unknown): Promise<void> {
    console.log('Received Kafka message:', message);
    // Add your business logic here.
    // Throw an error to trigger retry/DLQ handling.
  }

  /**
   * Dead Letter Queue consumer — processes messages that failed all retries.
   */
  @EventPattern('my-topic.dlq')
  async handleDLQ(@Payload() data: unknown): Promise<void> {
    console.error('Message moved to DLQ:', data);
    // Persist to database, alert, etc.
  }
}
