import { Module } from '@nestjs/common';
import { BullModule } from '@nestjs/bullmq';
import { ConfigModule, ConfigService } from '@nestjs/config';
<% if (dlqAndRetries) { %>import { ScheduleModule } from '@nestjs/schedule';<% } %>
import { BullMQProcessor } from './bullmq.processor';
import { BullMQProducerService } from './bullmq.producer.service';
<% if (dlqAndRetries) { %>import { BullMQDlqCron } from './bullmq.dlq.cron';<% } %>

@Module({
  imports: [
    BullModule.forRootAsync({
      imports: [ConfigModule],
      inject: [ConfigService],
      useFactory: (configService: ConfigService) => ({
        connection: {
          host: configService.get<string>('REDIS_HOST') || 'localhost',
          port: configService.get<number>('REDIS_PORT') || 6379,
          password: configService.get<string>('REDIS_PASSWORD'),
        },
      }),
    }),
    BullModule.registerQueue({
      name: '<%= projectName %>-queue',
      defaultJobOptions: {
        attempts: 3,
        backoff: {
          type: 'exponential',
          delay: 1000,
        },
        removeOnComplete: 100,
        removeOnFail: 500,
      },
    }),
    <% if (dlqAndRetries) { %>ScheduleModule.forRoot(),<% } %>
  ],
  providers: [
    BullMQProcessor, 
    BullMQProducerService,
    <% if (dlqAndRetries) { %>BullMQDlqCron,<% } %>
  ],
  exports: [BullModule, BullMQProducerService],
})
export class BullMQModule {}
