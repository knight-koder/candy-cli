import { Test, TestingModule } from '@nestjs/testing';
import { BullMQProcessor } from './bullmq.processor';
import { Job } from 'bullmq';

describe('BullMQProcessor', () => {
  let processor: BullMQProcessor;

  beforeEach(async () => {
    const module: TestingModule = await Test.createTestingModule({
      providers: [BullMQProcessor],
    }).compile();

    processor = module.get<BullMQProcessor>(BullMQProcessor);
  });

  it('should be defined', () => {
    expect(processor).toBeDefined();
  });

  it('process should handle a job without throwing', async () => {
    const mockJob = {
      id: '1',
      name: 'test-job',
      data: { foo: 'bar' },
    } as unknown as Job;

    await expect(processor.process(mockJob)).resolves.not.toThrow();
  });
});
