import { Module } from '@nestjs/common';
import { ClientsModule, Transport } from '@nestjs/microservices';
import { RabbitMQPublisherService } from './rabbitmq.publisher.service';
import { RabbitMQDLQConsumerController } from './rabbitmq.dlq.consumer';

@Module({
  imports: [
    ClientsModule.register([
      {
        name: 'RABBITMQ_SERVICE',
        transport: Transport.RMQ,
        options: {
          urls: [(process.env.RABBITMQ_URL || 'amqp://localhost:5672')],
          queue: '<%= projectName %>-queue',
          queueOptions: {
            durable: true,
            // Dead Letter Exchange configuration
            arguments: {
              'x-dead-letter-exchange': '<%= projectName %>-dlx',
              'x-dead-letter-routing-key': '<%= projectName %>-dlq',
              'x-message-ttl': 30000,
            },
          },
          prefetchCount: 1,
          isGlobalPrefetchCount: false,
        },
      },
    ]),
  ],
  controllers: [RabbitMQDLQConsumerController],
  providers: [RabbitMQPublisherService],
  exports: [ClientsModule, RabbitMQPublisherService],
})
export class RabbitMQModule {}
