import { Global, Module } from '@nestjs/common';
import { PostgresPrismaService } from './prisma.service';

/**
 * PostgresPrismaModule — provides PrismaService for PostgreSQL.
 *
 * Marked as @Global so PrismaService can be injected anywhere in the app
 * without needing to re-import this module.
 */
@Global()
@Module({
  providers: [PostgresPrismaService],
  exports: [PostgresPrismaService],
})
export class PostgresPrismaModule {}
