import {
  Entity,
  PrimaryGeneratedColumn,
  Column,
  CreateDateColumn,
  UpdateDateColumn,
  DeleteDateColumn,
  VersionColumn,
  Index,
} from 'typeorm';
<% if (apiDocs) { %>import { ApiProperty } from '@nestjs/swagger';<% } %>

export enum ExampleStatus {
  ACTIVE   = 'active',
  INACTIVE = 'inactive',
  PENDING  = 'pending',
}

/**
 * ExampleEntity — TypeORM reference entity for MySQL.
 *
 * One column per major type is shown. Delete what you don't need and
 * run migrations after any schema change:
 *   npx typeorm migration:generate src/migrations/InitSchema -d src/database/mysql/database.module.ts
 *
 * MySQL differences vs PostgreSQL:
 *   - No native array columns (use json instead)
 *   - No jsonb (use json)
 *   - Use datetime/timestamp instead of timestamptz
 *   - bigint returns as string from the mysql2 driver
 */
@Entity('examples')
export class ExampleEntity {
  // ── Primary Key ────────────────────────────────────────────────────────────
  @PrimaryGeneratedColumn('uuid')
  id: string;

  // ── String types ───────────────────────────────────────────────────────────
  @Index()
  <% if (apiDocs) { %>@ApiProperty({ example: 'My Entity', description: 'The name of the example entity' })<% } %>
  @Column({ type: 'varchar', length: 255 })
  name: string;

  <% if (apiDocs) { %>@ApiProperty({ example: 'USD', required: false })<% } %>
  @Column({ type: 'char', length: 3, nullable: true })
  code?: string;                                  // fixed-length char, e.g. 'USD'

  <% if (apiDocs) { %>@ApiProperty({ example: 'A detailed description', required: false })<% } %>
  @Column({ type: 'text', nullable: true })
  description?: string;                           // up to 65,535 bytes

  @Column({ type: 'mediumtext', nullable: true })
  body?: string;                                  // up to 16 MB

  @Column({ type: 'longtext', nullable: true })
  content?: string;                               // up to 4 GB

  // ── Numeric types ──────────────────────────────────────────────────────────
  <% if (apiDocs) { %>@ApiProperty({ example: 1, default: 0 })<% } %>
  @Column({ type: 'tinyint', default: 0 })
  priority: number;                               // -128 to 127

  <% if (apiDocs) { %>@ApiProperty({ example: 1, default: 0 })<% } %>
  @Column({ type: 'smallint', default: 0 })
  rank: number;                                   // -32768 to 32767

  <% if (apiDocs) { %>@ApiProperty({ example: 100, default: 0 })<% } %>
  @Column({ type: 'int', default: 0 })
  viewCount: number;                              // standard 32-bit integer

  @Column({ type: 'bigint', nullable: true })
  externalId?: string;                            // 64-bit int (returned as string by mysql2)

  @Column({ type: 'decimal', precision: 10, scale: 2, nullable: true })
  price?: number;                                 // fixed-point, e.g. 12345678.99

  @Column({ type: 'float', nullable: true })
  rating?: number;                                // 4-byte single-precision float

  @Column({ type: 'double', nullable: true })
  score?: number;                                 // 8-byte double-precision float

  // ── Boolean ────────────────────────────────────────────────────────────────
  <% if (apiDocs) { %>@ApiProperty({ example: true, default: true })<% } %>
  @Column({ type: 'boolean', default: true })
  isActive: boolean;                              // stored as tinyint(1) in MySQL

  // ── Enum ───────────────────────────────────────────────────────────────────
  <% if (apiDocs) { %>@ApiProperty({ enum: ExampleStatus, default: ExampleStatus.PENDING })<% } %>
  @Column({ type: 'enum', enum: ExampleStatus, default: ExampleStatus.PENDING })
  status: ExampleStatus;

  // ── Date / Time ────────────────────────────────────────────────────────────
  @Column({ type: 'date', nullable: true })
  birthDate?: string;                             // stored as YYYY-MM-DD

  @Column({ type: 'time', nullable: true })
  startTime?: string;                             // stored as HH:MM:SS

  @Column({ type: 'datetime', nullable: true })
  scheduledAt?: Date;                             // no timezone info stored

  @Column({ type: 'timestamp', nullable: true })
  expiresAt?: Date;                               // auto-converts to UTC; valid 1970–2038

  @Column({ type: 'year', nullable: true })
  graduationYear?: number;                        // stores YYYY (1901–2155)

  // ── JSON (MySQL 5.7.8+) ────────────────────────────────────────────────────
  @Column({ type: 'json', nullable: true })
  metadata?: Record<string, unknown>;             // validated JSON column (no binary index)

  // ── Binary ─────────────────────────────────────────────────────────────────
  @Column({ type: 'blob', nullable: true })
  thumbnail?: Buffer;                             // up to 65 KB binary

  @Column({ type: 'longblob', nullable: true })
  attachment?: Buffer;                            // up to 4 GB binary

  // ── Automatic metadata ─────────────────────────────────────────────────────
  @CreateDateColumn({ type: 'datetime' })
  createdAt: Date;

  @UpdateDateColumn({ type: 'datetime' })
  updatedAt: Date;

  @DeleteDateColumn({ type: 'datetime', nullable: true })
  deletedAt?: Date;                               // soft-delete support (use withDeleted())

  @VersionColumn()
  version: number;                                // optimistic locking — auto-incremented on update
}
