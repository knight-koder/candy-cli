// This is your Prisma schema file for MySQL.
// Learn more: https://pris.ly/d/prisma-schema
//
// NOTE: If you also have a PostgreSQL Prisma setup, each DB has its own schema.prisma
// since Prisma supports one datasource per schema file.
//
// Run migrations:
//   npx prisma migrate dev --schema=src/database/mysql/prisma/schema.prisma --name init
//
// Regenerate client after schema changes:
//   npx prisma generate --schema=src/database/mysql/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
  output   = "../generated"
}

datasource db {
  provider = "mysql"
  url      = env("MYSQL_URL")
}

// ─────────────────────────────────────────────
// Starter model — replace with your domain models
// ─────────────────────────────────────────────
model Example {
  id          String   @id @default(uuid())
  name        String   @db.VarChar(255)
  description String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("examples")
}
